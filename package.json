{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "lint": "eslint . --ext .js",
    "format": "prettier --write .",
    "test": "jest --forceExit --detectOpenHandles",
    "migrate": "npx sequelize-cli db:migrate --config src/infrastructure/database/config/config.js --migrations-path src/infrastructure/database/migrations",
    "migrate:undo": "npx sequelize-cli db:migrate:undo --config src/infrastructure/database/config/config.js --migrations-path src/infrastructure/database/migrations",
    "seed": "npx sequelize-cli db:seed:all",
    "docker:build": "docker build -t restaurant-saas .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "prepare": "husky install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "awilix": "^13.0.3",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "envalid": "^8.1.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "redis": "^5.11.0",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5",
    "twilio": "^5.12.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
